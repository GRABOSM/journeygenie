# --- Option A: Local / trusted deploy (keys in env; visible in browser network tab) ---
# OpenWeather API — https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Grab Maps API
REACT_APP_GRAB_MAPS_API_URL=https://maps.grab.com
REACT_APP_GRAB_MAPS_API_KEY=your_grab_maps_api_key_here

# --- Option B: Public static site (GitHub Pages) — keys only on edge worker, not in bundle ---
# Deploy workers/journeygenie-api-proxy (see workers/journeygenie-api-proxy/README.md), then:
# REACT_APP_API_PROXY_URL=https://your-worker.workers.dev
# Omit REACT_APP_GRAB_MAPS_API_KEY and REACT_APP_OPENWEATHER_API_KEY from the build.
# Optional: set to true to keep vector traffic overlay from style.json (default strips it if traffic tile CDN returns 502)
# REACT_APP_GRAB_MAP_KEEP_TRAFFIC_TILES=true

# Environment Configuration
REACT_APP_ENVIRONMENT=development
